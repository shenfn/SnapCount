{
  "name": "snapcount",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "logs:ai": "node --env-file=.env.local scripts/show-ai-logs.mjs",
    "test:receipt": "node --env-file=.env.local scripts/test-ingest-receipt.mjs",
    "cleanup:test-receipts": "node --env-file=.env.local scripts/cleanup-test-receipts.mjs",
    "test:image-cleanup": "node scripts/test-image-cleanup-lifecycle.mjs",
    "test:expression-feedback": "node scripts/test-expression-feedback.mjs",
    "test:registration-consent": "node --env-file=.env.local scripts/test-registration-consent.mjs",
    "test:finance-options": "node scripts/test-finance-review-options.mjs",
    "check:receipt-dedup": "node scripts/check-receipt-dedup-contracts.mjs",
    "check:security-contracts": "node scripts/check-security-contracts.mjs",
    "audit:storage-orphans": "node scripts/audit-storage-orphans.mjs",
    "migrate:legacy-signed-images": "node scripts/migrate-legacy-signed-image-urls.mjs",
    "trace:server": "node tools/ai-validation/server/index.mjs",
    "trace:ui": "cd tools/ai-validation/ui/trace-console && npm run dev",
    "trace:console": "node tools/ai-validation/start.mjs",
    "trace:extract-prompt": "cd tools/ai-validation/server && npx tsx extract-prompt.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "chart.js": "^4.5.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "vconsole": "^3.15.1",
    "vite": "^5.0.0"
  }
}
